#include <stdlib.h>
#include <unistd.h>
#include <signal.h>
#include <sys/wait.h>

void handler(int sig) {
    int status;
    while (waitpid(-1, &status, WNOHANG) > 0) {
        write(STDOUT_FILENO, "Child exited\n", 13);
    }
}

int main() {
    struct sigaction sa;
    sa.sa_handler = handler;
    sigemptyset(&sa.sa_mask);
    sa.sa_flags = SA_RESTART;
    sigaction(SIGCHLD, &sa, NULL);

    pid_t pid = fork();

    if (pid == 0) {
        sleep(2);
        _exit(0);
    }

    while (1) {
        pause();
    }

    return 0;
}

