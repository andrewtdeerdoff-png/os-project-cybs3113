#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/mman.h>
#include <sys/stat.h>
#include <fcntl.h>
#include <sys/wait.h>

int main() {
    const char *name = "/my_shm";
    int shm_fd = shm_open(name, O_CREAT | O_RDWR, 0666);
    ftruncate(shm_fd, sizeof(int));
    int *ptr = mmap(0, sizeof(int), PROT_READ | PROT_WRITE, MAP_SHARED, shm_fd, 0);

    *ptr = 10;

    pid_t pid = fork();

    if (pid == 0) {
        *ptr = 42;
        munmap(ptr, sizeof(int));
        close(shm_fd);
        exit(0);
    } else {
        wait(NULL);
        printf("%d\n", *ptr);
        munmap(ptr, sizeof(int));
        close(shm_fd);
        shm_unlink(name);
    }

    return 0;
}

