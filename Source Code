#include <sys/stat.h>

int main() {
    const char *filename = "testfile.bin";
    int fd = open(filename, O_RDWR | O_CREAT, 0666);
    if (fd < 0) return 1;

    if (ftruncate(fd, 1024) == -1) {
        close(fd);
        return 1;
    }

    char *data = mmap(NULL, 1024, PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);
    if (data == MAP_FAILED) {
        close(fd);
        return 1;
    }

    for (int i = 1023; i >= 0; i--) {
        putchar(data[i]);
    }

    munmap(data, 1024);
    close(fd);
    return 0;
}

